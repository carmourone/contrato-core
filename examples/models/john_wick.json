      "blob": {
        "name": "High Table Authority",
        "ref": "policy:high-table-authority:v1",
        "engine": "opa",
        "source": "package contrato.policies.high_table_authority_v1\n\nimport rego.v1\n\ndefault decision := {\"action\": \"deny\", \"reasons\": [\"HT-NOAUTH\"], \"obligations\": []}\n\ndecision := {\n    \"action\": \"allow\",\n    \"reasons\": [\"HT-SANCTIONED\"],\n    \"obligations\": [{\"name\": \"log\", \"params\": {\"registry\": \"high_table\"}}]\n} if {\n    input.actor.roles[_] == \"high_table_member\"\n}\n\ndecision := {\n    \"action\": \"require_approval\",\n    \"reasons\": [\"HT-ESCALATE\"],\n    \"obligations\": [{\"name\": \"escalate_to_human\", \"params\": {\"escalate_to\": \"adjudicator\"}}]\n} if {\n    input.actor.roles[_] == \"continental_manager\"\n}\n",
        "opa": {
          "package": "contrato.policies.high_table_authority_v1",
          "rule": "decision",
          "decision_examples": [
            {
              "input":  { "actor": { "roles": ["high_table_member"] } },
              "output": { "action": "allow", "reasons": ["HT-SANCTIONED"] }
            }
          ]
        }
