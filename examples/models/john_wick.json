      "type": "policy",
      "blob": {
        "name": "Continental Rules",
        "ref": "policy:continental-rules:v1",
        "engine": "opa",
        "source": "package contrato.policies.continental_rules_v1\n\nimport rego.v1\n\ndefault decision := {\"action\": \"allow\", \"reasons\": [], \"obligations\": []}\n\ndecision := {\n    \"action\": \"deny\",\n    \"reasons\": [\"JW-NO-BIZ\"],\n    \"obligations\": [{\"name\": \"notify\", \"params\": {\"channel\": \"management\"}}]\n} if {\n    input.action.requested == \"conduct_business\"\n    input.action.context.location == \"continental\"\n}\n\ndecision := {\n    \"action\": \"require_approval\",\n    \"reasons\": [\"JW-TABLE\"],\n    \"obligations\": [{\"name\": \"escalate_to_human\", \"params\": {\"escalate_to\": \"high_table\"}}]\n} if {\n    input.action.requested == \"break_rules\"\n}\n",
        "opa": {
          "package": "contrato.policies.continental_rules_v1",
          "rule": "decision",
          "decision_examples": [
            {
              "input":  { "action": { "requested": "conduct_business", "context": { "location": "continental" } } },
              "output": { "action": "deny", "reasons": ["JW-NO-BIZ"], "obligations": [{ "name": "notify", "params": { "channel": "management" } }] }
            },
            {
              "input":  { "action": { "requested": "escort_client",    "context": { "location": "continental" } } },
              "output": { "action": "allow", "reasons": [], "obligations": [] }
            }
          ]
        }
      }
    },
    {
      "id": "aaaa0001-0000-0000-0000-000000000031",
