    {
      "id": "bbbb0001-0000-0000-0000-000000000060",
      "type": "policy",
      "blob": {
        "name": "OBP Selection Policy",
        "ref": "policy:obp-selection:v1",
        "principle": "Select players based on on-base percentage, not traditional scouting metrics",
        "engine": "opa",
        "source": "package contrato.policies.obp_selection_v1\n\nimport rego.v1\n\ndefault decision := {\"action\": \"deny\", \"reasons\": [\"MB-BELOW-THRESHOLD\"], \"obligations\": []}\n\ndecision := {\n    \"action\": \"allow\",\n    \"reasons\": [\"MB-OBP-QUALIFIES\"],\n    \"obligations\": [{\"name\": \"log\", \"params\": {\"metric\": \"obp\"}}]\n} if {\n    input.action.context.obp >= 0.360\n    input.action.context.salary_musd <= 2.0\n}\n\ndecision := {\n    \"action\": \"require_approval\",\n    \"reasons\": [\"MB-BORDERLINE\"],\n    \"obligations\": [{\"name\": \"escalate_to_human\", \"params\": {\"escalate_to\": \"gm\"}}]\n} if {\n    input.action.context.obp >= 0.330\n    input.action.context.obp < 0.360\n    input.action.context.salary_musd <= 2.0\n}\n",
        "opa": {
          "package": "contrato.policies.obp_selection_v1",
          "rule": "decision",
          "decision_examples": [
            {
              "input":  { "action": { "requested": "sign_player", "context": { "obp": 0.389, "salary_musd": 0.95 } } },
              "output": { "action": "allow", "reasons": ["MB-OBP-QUALIFIES"], "obligations": [{ "name": "log", "params": { "metric": "obp" } }] }
            },
            {
              "input":  { "action": { "requested": "sign_player", "context": { "obp": 0.290, "salary_musd": 8.0 } } },
              "output": { "action": "deny",  "reasons": ["MB-BELOW-THRESHOLD"], "obligations": [] }
            }
          ]
        }
      }
    },
    {
      "id": "bbbb0001-0000-0000-0000-000000000061",
      "type": "policy",
      "blob": {
        "name": "Payroll Efficiency Policy",
        "ref": "policy:payroll-efficiency:v1",
        "principle": "Maximise wins above replacement per dollar of payroll",
        "engine": "opa",
        "source": "package contrato.policies.payroll_efficiency_v1\n\nimport rego.v1\n\ndefault decision := {\"action\": \"deny\", \"reasons\": [\"MB-OVER-BUDGET\"], \"obligations\": []}\n\ndecision := {\n    \"action\": \"allow\",\n    \"reasons\": [\"MB-EFFICIENT\"],\n    \"obligations\": [{\"name\": \"log\", \"params\": {\"metric\": \"war_per_dollar\"}}]\n} if {\n    input.action.context.war_per_dollar >= 2.0\n}\n\ndecision := {\n    \"action\": \"require_approval\",\n    \"reasons\": [\"MB-REVIEW\"],\n    \"obligations\": [{\"name\": \"escalate_to_human\", \"params\": {\"escalate_to\": \"owner\"}}]\n} if {\n    input.action.context.war_per_dollar >= 1.0\n    input.action.context.war_per_dollar < 2.0\n}\n",
        "opa": {
          "package": "contrato.policies.payroll_efficiency_v1",
          "rule": "decision"
        }
      }
    },
